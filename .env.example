# ============================================================
# SewaSetu RAG Backend - Environment Configuration Template
# ============================================================

# --- Ollama LLM Settings ---
# The local Ollama model to use for answer generation (if USE_SARVAM_API is false)
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_BASE_URL=http://localhost:11434

# --- Embedding Model ---
# intfloat/multilingual-e5-large is used for semantic embedding search
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Vector Store (ChromaDB) ---
# Path to the persistent ChromaDB directory
CHROMA_DB_PATH=./04_embeddings_and_kg/chroma_db

# --- Debug / Logging ---
# Set to "true" to print retrieved chunks and timing info to the console
DEBUG_PRINT_CHUNKS=true

# --- Sarvam AI Settings ---
# Set to "true" to use Sarvam AI API instead of local Ollama
USE_SARVAM_API=true
# Paste your Sarvam AI API subscription key below
SARVAM_API_KEY=your_sarvam_api_key_here
# The Sarvam AI model name (using sarvam-30b)
SARVAM_MODEL=sarvam-30b
# Sarvam API Endpoint URL
SARVAM_API_URL=https://api.sarvam.ai/v1/chat/completions

# --- OCR Dependencies ---
# Path to the poppler binary folder on Windows (required if running ocr_pdfs.py)
POPPLER_PATH=C:\path\to\poppler\bin
