# ============================================================
# SewaSetu RAG Backend - Environment Configuration
# ============================================================

# --- Ollama LLM Settings ---
# The local Ollama model to use for answer generation
OLLAMA_MODEL=qwen2.5-coder:14b
# Ollama server base URL
OLLAMA_BASE_URL=http://localhost:11434

# --- Embedding Model ---
# intfloat/multilingual-e5-large as required by the prompt
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# --- Vector Store (ChromaDB) ---
# Path to the persistent ChromaDB directory
CHROMA_DB_PATH=./chroma_db

# --- Debug / Logging ---
# Set to "true" to print retrieved chunks and timing info to the console
DEBUG_PRINT_CHUNKS=true

# --- Sarvam AI Settings ---
# Set to "true" to use Sarvam AI API instead of local Ollama
USE_SARVAM_API=true
# Paste your Sarvam AI API subscription key below
SARVAM_API_KEY=sk_r1uf6dhn_qMA7bXl8p2YkMI6GB3HB7uwK
# The Sarvam AI model name (using sarvam-2b or sarvam-m)
SARVAM_MODEL=sarvam-30b
# Sarvam API Endpoint URL
SARVAM_API_URL=https://api.sarvam.ai/v1/chat/completions

# --- OCR Dependencies ---
# Path to the poppler binary folder on Windows
POPPLER_PATH=C:\Release-26.02.0-0\poppler-26.02.0\Library\bin
